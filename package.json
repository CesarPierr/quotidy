{
  "name": "quotidy",
  "version": "0.1.0",
  "private": true,
  "description": "App self-hostable de gestion équitable du foyer — ménage et épargne partagée.",
  "homepage": "https://github.com/CesarPierr/quotidy#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CesarPierr/quotidy.git"
  },
  "bugs": {
    "url": "https://github.com/CesarPierr/quotidy/issues"
  },
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "household",
    "chores",
    "tasks",
    "recurring",
    "pwa",
    "nextjs",
    "self-hosted",
    "prisma"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "node --import tsx prisma/seed.ts",
    "db:seed:stress": "node --import tsx prisma/seed-stress.ts",
    "deploy:local-prod": "docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build",
    "deploy:server-sync": "bash scripts/deploy/sync-to-server.sh",
    "deploy:install-local-cron": "bash scripts/server/install-local-cron.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ical-generator": "^10.2.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.9",
    "nodemailer": "^8.0.6",
    "prisma": "^6.19.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.0.2",
    "start-server-and-test": "^3.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
