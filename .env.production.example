POSTGRES_DB=quotidy
POSTGRES_USER=quotidy
POSTGRES_PASSWORD=change-me
APP_BASE_URL=https://taches.example.com
APP_HOST=taches.example.com
NEXT_PUBLIC_APP_NAME=Quotidy
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com
NEXT_PUBLIC_SUPPORT_URL=
AUTH_SECRET=change-me-to-a-long-random-string
CSRF_SECRET=change-me-to-a-long-random-string
CRON_SECRET=change-me-to-a-long-random-string
ADMIN_EMAILS=
BILLING_ENABLED=0
GITHUB_REPORT_REPO=
GITHUB_REPORT_TOKEN=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@quotidy.fr
DEFAULT_TIMEZONE=Europe/Paris
OCCURRENCE_PAST_DAYS=30
OCCURRENCE_FUTURE_DAYS=60

# Optional: public HTTPS via Tailscale Funnel (the "funnel" compose profile).
# A reusable auth key from https://login.tailscale.com/admin/settings/keys.
# With APP_BASE_URL/APP_HOST = https://<host>.<tailnet>.ts.net. See docs/native-app.md.
TS_AUTHKEY=
TS_HOSTNAME=quotidy-server
