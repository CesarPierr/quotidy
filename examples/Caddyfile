# ─────────────────────────────────────────────────────────────────────────────
# Quotidy reverse proxy. Two front doors share one upstream (app:3000):
#   • LAN / Freebox WireGuard      → plain http (transport already private)
#   • Public Tailscale Funnel      → https, terminated at the Tailscale edge
#
# Funnel forwards over loopback already setting X-Forwarded-{Proto,For,Host}, but
# Caddy overwrites X-Forwarded-Proto with this internal http hop's scheme. So we
# detect funnel requests by the Tailscale-Funnel-Request header and force the
# proto back to https — otherwise the app builds http:// absolute URLs (dead
# redirects, e.g. invite links) and skips Secure cookies. trusted_proxies lets
# the real client IP (not loopback) reach the app's rate-limiter on that path.
# ─────────────────────────────────────────────────────────────────────────────
{
  servers {
    trusted_proxies static 127.0.0.1/32 ::1/128
  }
}

:80 {
  encode gzip zstd

  @funnel header Tailscale-Funnel-Request *
  handle @funnel {
    reverse_proxy app:3000 {
      header_up X-Forwarded-Proto https
    }
  }

  handle {
    reverse_proxy app:3000
  }
}
