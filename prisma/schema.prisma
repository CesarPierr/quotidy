generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HouseholdRole {
  owner
  admin
  member
}

enum AvailabilityType {
  weekly_rule
  date_range_absence
}

enum RecurrenceType {
  daily
  every_x_days
  weekly
  every_x_weeks
  monthly_simple
}

enum RecurrenceMode {
  FIXED
  SLIDING
}

enum AssignmentMode {
  fixed
  manual
  strict_alternation
  round_robin
  least_assigned_count
  least_assigned_minutes
}

enum OccurrenceStatus {
  planned
  due
  overdue
  completed
  skipped
  rescheduled
  cancelled
}

enum OccurrenceActionType {
  created
  assigned
  completed
  skipped
  rescheduled
  reassigned
  edited
  cancelled
}

enum IntegrationProvider {
  mcp_openclaw
}

enum FeedbackKind {
  bug
  idea
  question
  abuse
  billing
  security
}

enum FeedbackStatus {
  open
  triaged
  resolved
  archived
}

enum DataRequestStatus {
  requested
  processing
  completed
  rejected
}

enum BillingInterval {
  month
  year
  one_time
}

enum SubscriptionStatus {
  beta
  trialing
  active
  past_due
  canceled
  inactive
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  passwordHash           String
  displayName            String
  isSiteAdmin            Boolean                 @default(false)
  emailVerifiedAt        DateTime?
  deletedAt              DateTime?
  termsAcceptedAt        DateTime?
  privacyAcceptedAt      DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  lastLoginAt            DateTime?
  sessions               Session[]
  passwordResetTokens    PasswordResetToken[]
  memberships            HouseholdMember[]
  households             Household[]             @relation("HouseholdOwner")
  acceptedInvitations    HouseholdInvite[]       @relation("AcceptedHouseholdInvites")
  feedbackReports        FeedbackReport[]
  uxEvents               UxEvent[]
  adminAuditEvents       AdminAuditEvent[]       @relation("AdminAuditActor")
  dataExportRequests     DataExportRequest[]
  deletionRequests       DeletionRequest[]
  supporterContributions SupporterContribution[]
  billingCustomers       BillingCustomer[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Household {
  id                     String                  @id @default(cuid())
  name                   String
  timezone               String
  /// When false, the Épargne (savings) module is hidden from this household's
  /// navigation and onboarding skips its dedicated steps. The data and routes
  /// remain accessible if the user toggles it back on later.
  savingsEnabled         Boolean                 @default(true)
  /// Retention window (in days) for completed foyer notes before they are
  /// purged from the "Fait" list. Configurable per household; default one week.
  noteRetentionDays      Int                     @default(7)
  createdByUserId        String
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  createdBy              User                    @relation("HouseholdOwner", fields: [createdByUserId], references: [id])
  members                HouseholdMember[]
  invites                HouseholdInvite[]
  integrations           HouseholdIntegration[]
  tasks                  TaskTemplate[]
  occurrences            TaskOccurrence[]
  holidays               HouseholdHoliday[]
  savingsBoxes           SavingsBox[]
  savingsCalculators     SavingsCalculator[]
  feedbackReports        FeedbackReport[]
  uxEvents               UxEvent[]
  adminAuditEvents       AdminAuditEvent[]
  dataExportRequests     DataExportRequest[]
  deletionRequests       DeletionRequest[]
  supporterContributions SupporterContribution[]
  billingCustomers       BillingCustomer[]
  subscriptions          Subscription[]
  featureEntitlements    FeatureEntitlement[]
  checklists             Checklist[]
  householdNotes         HouseholdNote[]
  budgetIncomes          BudgetIncome[]
  budgetCharges          BudgetCharge[]
  budgetPockets          BudgetPocket[]
  budgetExpenses         BudgetExpense[]

  @@index([createdByUserId])
}

model HouseholdMember {
  id                    String                @id @default(cuid())
  householdId           String
  userId                String?
  displayName           String
  color                 String
  role                  HouseholdRole
  isActive              Boolean               @default(true)
  weightingFactor       Float                 @default(1)
  weeklyCapacityMinutes Int?
  onboardingCompletedAt DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  household             Household             @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user                  User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  availabilities        MemberAvailability[]
  createdTasks          TaskTemplate[]        @relation("TaskTemplateCreator")
  createdInvitations    HouseholdInvite[]     @relation("CreatedHouseholdInvites")
  assignedOccurrences   TaskOccurrence[]      @relation("OccurrenceAssignee")
  completedOccurrences  TaskOccurrence[]      @relation("OccurrenceCompleter")
  actionLogs            OccurrenceActionLog[]
  occurrenceComments    OccurrenceComment[]
  pushSubscriptions     PushSubscription[]
  createdChecklists     Checklist[]           @relation("ChecklistCreator")
  checkedChecklistItems ChecklistItem[]       @relation("ChecklistItemChecker")
  createdNotes          HouseholdNote[]       @relation("HouseholdNoteCreator")
  completedNotes        HouseholdNote[]       @relation("HouseholdNoteCompleter")
  budgetExpenses        BudgetExpense[]       @relation("BudgetExpenseCreator")

  @@unique([householdId, userId])
  @@index([householdId])
  @@index([userId])
}

model HouseholdInvite {
  id                String           @id @default(cuid())
  householdId       String
  createdByMemberId String?
  acceptedByUserId  String?
  token             String           @unique
  code              String           @unique
  role              HouseholdRole    @default(member)
  expiresAt         DateTime
  acceptedAt        DateTime?
  revokedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  household         Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdByMember   HouseholdMember? @relation("CreatedHouseholdInvites", fields: [createdByMemberId], references: [id], onDelete: SetNull)
  acceptedByUser    User?            @relation("AcceptedHouseholdInvites", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([householdId, createdAt])
  @@index([expiresAt])
}

model HouseholdIntegration {
  id            String              @id @default(cuid())
  householdId   String
  provider      IntegrationProvider
  isEnabled     Boolean             @default(false)
  serverUrl     String?
  clientLabel   String?
  apiKeyHash    String?
  apiKeyPreview String?
  config        Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  household     Household           @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, provider])
  @@index([provider, isEnabled])
}

model MemberAvailability {
  id        String           @id @default(cuid())
  memberId  String
  type      AvailabilityType
  weekdays  Json?
  startDate DateTime
  endDate   DateTime
  notes     String?
  createdAt DateTime         @default(now())
  member    HouseholdMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, startDate, endDate])
}

model RecurrenceRule {
  id                String         @id @default(cuid())
  type              RecurrenceType
  mode              RecurrenceMode @default(SLIDING)
  interval          Int            @default(1)
  weekdays          Json?
  dayOfMonth        Int?
  anchorDate        DateTime
  generateTimeOfDay String?
  dueOffsetDays     Int            @default(0)
  config            Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  task              TaskTemplate?
}

model AssignmentRule {
  id                           String         @id @default(cuid())
  mode                         AssignmentMode
  eligibleMemberIds            Json
  fixedMemberId                String?
  rotationOrder                Json?
  fairnessWindowDays           Int?
  preserveRotationOnSkip       Boolean        @default(true)
  preserveRotationOnReschedule Boolean        @default(true)
  rebalanceOnMemberAbsence     Boolean        @default(true)
  lockAssigneeAfterGeneration  Boolean        @default(true)
  config                       Json?
  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt
  task                         TaskTemplate?
}

model TaskTemplate {
  id                String           @id @default(cuid())
  householdId       String
  title             String
  description       String?
  category          String?
  room              String?
  icon              String?
  color             String           @default("#D8643D")
  tags              Json?
  estimatedMinutes  Int              @default(30)
  difficulty        Int?
  priority          Int              @default(2)
  isActive          Boolean          @default(true)
  isCollective      Boolean          @default(false)
  startsOn          DateTime
  endsOn            DateTime?
  lastCompletedAt   DateTime?
  recurrenceRuleId  String           @unique
  assignmentRuleId  String           @unique
  createdByMemberId String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  household         Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recurrenceRule    RecurrenceRule   @relation(fields: [recurrenceRuleId], references: [id], onDelete: Cascade)
  assignmentRule    AssignmentRule   @relation(fields: [assignmentRuleId], references: [id], onDelete: Cascade)
  createdByMember   HouseholdMember? @relation("TaskTemplateCreator", fields: [createdByMemberId], references: [id], onDelete: SetNull)
  occurrences       TaskOccurrence[]
  checklists        Checklist[]

  @@index([householdId])
}

model TaskOccurrence {
  id                    String                @id @default(cuid())
  householdId           String
  taskTemplateId        String
  scheduledDate         DateTime
  dueDate               DateTime
  assignedMemberId      String?
  status                OccurrenceStatus      @default(planned)
  sourceGenerationKey   String                @unique
  generationVersion     Int                   @default(1)
  originalScheduledDate DateTime
  completedAt           DateTime?
  completedByMemberId   String?
  actualMinutes         Int?
  notes                 String?
  wasCompletedAlone     Boolean?
  isManuallyModified    Boolean               @default(false)
  rescheduleCount       Int                   @default(0)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  household             Household             @relation(fields: [householdId], references: [id], onDelete: Cascade)
  taskTemplate          TaskTemplate          @relation(fields: [taskTemplateId], references: [id], onDelete: Cascade)
  assignedMember        HouseholdMember?      @relation("OccurrenceAssignee", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  completedByMember     HouseholdMember?      @relation("OccurrenceCompleter", fields: [completedByMemberId], references: [id], onDelete: SetNull)
  logs                  OccurrenceActionLog[]
  comments              OccurrenceComment[]

  @@index([householdId, scheduledDate])
  @@index([householdId, status, scheduledDate])
  @@index([householdId, assignedMemberId, scheduledDate])
  @@index([assignedMemberId, scheduledDate])
  @@index([taskTemplateId])
}

model HouseholdHoliday {
  id          String    @id @default(cuid())
  householdId String
  startDate   DateTime
  endDate     DateTime
  label       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, startDate])
}

model OccurrenceActionLog {
  id             String               @id @default(cuid())
  occurrenceId   String
  actionType     OccurrenceActionType
  actorMemberId  String?
  previousValues Json?
  newValues      Json?
  createdAt      DateTime             @default(now())
  occurrence     TaskOccurrence       @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  actorMember    HouseholdMember?     @relation(fields: [actorMemberId], references: [id], onDelete: SetNull)

  @@index([occurrenceId])
}

model OccurrenceComment {
  id           String           @id @default(cuid())
  occurrenceId String
  authorId     String?
  body         String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  occurrence   TaskOccurrence   @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  author       HouseholdMember? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([occurrenceId, createdAt])
}

model PushSubscription {
  id        String          @id @default(cuid())
  memberId  String
  endpoint  String          @unique
  p256dh    String
  auth      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  member    HouseholdMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

enum SavingsBoxKind {
  savings
  project
  debt
  provision
}

enum SavingsEntryType {
  deposit
  withdrawal
  transfer_in
  transfer_out
  auto_fill
  adjustment
}

enum SavingsCalculatorFieldType {
  number
  amount
  percent
}

enum SavingsCalculatorResultMode {
  deposit
  withdrawal
  none
}

enum SavingsCalculatorNegativeMode {
  clamp_to_zero
  convert_to_opposite
}

enum SavingsCalculatorRoundingMode {
  cents
  euro_floor
  euro_ceil
  euro_nearest
}

model SavingsBox {
  id                String         @id @default(cuid())
  householdId       String
  name              String
  kind              SavingsBoxKind @default(savings)
  icon              String?
  color             String         @default("#D8643D")
  targetAmount      Decimal?       @db.Decimal(12, 2)
  targetDate        DateTime?
  allowNegative     Boolean        @default(false)
  isArchived        Boolean        @default(false)
  sortOrder         Int            @default(0)
  notes             String?
  createdByMemberId String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  household      Household              @relation(fields: [householdId], references: [id], onDelete: Cascade)
  autoFillRule   SavingsAutoFillRule?
  entries        SavingsEntry[]
  outTransfers   SavingsTransfer[]      @relation("TransferFrom")
  inTransfers    SavingsTransfer[]      @relation("TransferTo")
  calculators    SavingsCalculator[]
  calculatorRuns SavingsCalculatorRun[]
  budgetCharges  BudgetCharge[]

  @@index([householdId, isArchived, sortOrder])
}

model SavingsAutoFillRule {
  id            String         @id @default(cuid())
  boxId         String         @unique
  amount        Decimal        @db.Decimal(12, 2)
  type          RecurrenceType
  interval      Int            @default(1)
  weekdays      Json?
  dayOfMonth    Int?
  anchorDate    DateTime
  startsOn      DateTime
  endsOn        DateTime?
  isPaused      Boolean        @default(false)
  lastAppliedOn DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  box SavingsBox @relation(fields: [boxId], references: [id], onDelete: Cascade)
}

model SavingsEntry {
  id             String           @id @default(cuid())
  boxId          String
  householdId    String
  type           SavingsEntryType
  amount         Decimal          @db.Decimal(12, 2)
  occurredOn     DateTime
  reason         String?
  authorMemberId String?
  transferId     String?
  autoFillRuleId String?
  autoFillKey    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  box           SavingsBox            @relation(fields: [boxId], references: [id], onDelete: Cascade)
  transfer      SavingsTransfer?      @relation(fields: [transferId], references: [id], onDelete: SetNull)
  calculatorRun SavingsCalculatorRun?

  @@unique([autoFillRuleId, autoFillKey])
  @@index([boxId, occurredOn])
  @@index([householdId, occurredOn])
  @@index([transferId])
}

model SavingsTransfer {
  id             String   @id @default(cuid())
  householdId    String
  fromBoxId      String
  toBoxId        String
  amount         Decimal  @db.Decimal(12, 2)
  occurredOn     DateTime
  reason         String?
  authorMemberId String?
  createdAt      DateTime @default(now())

  fromBox SavingsBox     @relation("TransferFrom", fields: [fromBoxId], references: [id], onDelete: Cascade)
  toBox   SavingsBox     @relation("TransferTo", fields: [toBoxId], references: [id], onDelete: Cascade)
  entries SavingsEntry[]

  @@index([householdId, occurredOn])
  @@index([fromBoxId])
  @@index([toBoxId])
}

model SavingsCalculator {
  id                String                        @id @default(cuid())
  householdId       String
  boxId             String?
  name              String
  description       String?
  formula           String
  reasonTemplate    String?
  resultMode        SavingsCalculatorResultMode   @default(deposit)
  negativeMode      SavingsCalculatorNegativeMode @default(clamp_to_zero)
  roundingMode      SavingsCalculatorRoundingMode @default(cents)
  isArchived        Boolean                       @default(false)
  sortOrder         Int                           @default(0)
  createdByMemberId String?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  household Household                @relation(fields: [householdId], references: [id], onDelete: Cascade)
  box       SavingsBox?              @relation(fields: [boxId], references: [id], onDelete: SetNull)
  fields    SavingsCalculatorField[]
  runs      SavingsCalculatorRun[]

  @@index([householdId, isArchived, sortOrder])
  @@index([boxId, isArchived, sortOrder])
}

model SavingsCalculatorField {
  id           String                     @id @default(cuid())
  calculatorId String
  key          String
  label        String
  type         SavingsCalculatorFieldType @default(number)
  defaultValue Decimal?                   @db.Decimal(12, 4)
  helperText   String?
  isRequired   Boolean                    @default(true)
  sortOrder    Int                        @default(0)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  calculator SavingsCalculator @relation(fields: [calculatorId], references: [id], onDelete: Cascade)

  @@unique([calculatorId, key])
  @@index([calculatorId, sortOrder])
}

model SavingsCalculatorRun {
  id             String           @id @default(cuid())
  calculatorId   String
  householdId    String
  boxId          String?
  inputValues    Json
  rawResult      Decimal          @db.Decimal(12, 4)
  resultAmount   Decimal          @db.Decimal(12, 2)
  entryType      SavingsEntryType
  entryId        String?          @unique
  authorMemberId String?
  createdAt      DateTime         @default(now())

  calculator SavingsCalculator @relation(fields: [calculatorId], references: [id], onDelete: Cascade)
  box        SavingsBox?       @relation(fields: [boxId], references: [id], onDelete: Cascade)
  entry      SavingsEntry?     @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([calculatorId, createdAt])
  @@index([householdId, createdAt])
  @@index([boxId, createdAt])
}

model FeedbackReport {
  id             String         @id @default(cuid())
  kind           FeedbackKind
  status         FeedbackStatus @default(open)
  message        String
  url            String?
  digest         String?
  userAgent      String?
  reporterUserId String?
  householdId    String?
  githubUrl      String?
  adminNotes     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  reporter       User?          @relation(fields: [reporterUserId], references: [id], onDelete: SetNull)
  household      Household?     @relation(fields: [householdId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([reporterUserId, createdAt])
  @@index([householdId, createdAt])
}

model UxEvent {
  id          String     @id @default(cuid())
  event       String
  userId      String?
  householdId String?
  path        String?
  props       Json?
  createdAt   DateTime   @default(now())
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  household   Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)

  @@index([event, createdAt])
  @@index([userId, createdAt])
  @@index([householdId, createdAt])
}

model AdminAuditEvent {
  id          String     @id @default(cuid())
  actorUserId String?
  householdId String?
  action      String
  targetType  String?
  targetId    String?
  metadata    Json?
  createdAt   DateTime   @default(now())
  actor       User?      @relation("AdminAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  household   Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([actorUserId, createdAt])
  @@index([householdId, createdAt])
}

model DataExportRequest {
  id          String            @id @default(cuid())
  userId      String
  householdId String?
  status      DataRequestStatus @default(requested)
  completedAt DateTime?
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  household   Household?        @relation(fields: [householdId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([householdId, createdAt])
  @@index([status, createdAt])
}

model DeletionRequest {
  id          String            @id @default(cuid())
  userId      String?
  householdId String?
  status      DataRequestStatus @default(requested)
  reason      String?
  completedAt DateTime?
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  household   Household?        @relation(fields: [householdId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([householdId, createdAt])
  @@index([status, createdAt])
}

model SupporterContribution {
  id          String     @id @default(cuid())
  userId      String?
  householdId String?
  provider    String     @default("manual")
  providerRef String?
  amountCents Int?
  currency    String     @default("EUR")
  message     String?
  isPublic    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  household   Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([householdId, createdAt])
  @@index([provider, providerRef])
}

model Plan {
  id            String          @id @default(cuid())
  code          String          @unique
  name          String
  description   String?
  priceCents    Int             @default(0)
  currency      String          @default("EUR")
  interval      BillingInterval @default(month)
  isActive      Boolean         @default(true)
  entitlements  Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  subscriptions Subscription[]

  @@index([isActive, code])
}

model BillingCustomer {
  id                 String     @id @default(cuid())
  userId             String?
  householdId        String?
  provider           String     @default("stripe")
  providerCustomerId String
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  user               User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  household          Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)

  @@unique([provider, providerCustomerId])
  @@index([userId])
  @@index([householdId])
}

model Subscription {
  id                     String             @id @default(cuid())
  householdId            String
  planId                 String?
  status                 SubscriptionStatus @default(beta)
  provider               String             @default("internal")
  providerSubscriptionId String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  household              Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  plan                   Plan?              @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@unique([provider, providerSubscriptionId])
  @@index([householdId, status])
  @@index([planId])
}

model FeatureEntitlement {
  id          String    @id @default(cuid())
  householdId String
  feature     String
  enabled     Boolean   @default(true)
  limitValue  Int?
  source      String    @default("beta")
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, feature])
  @@index([feature, enabled])
  @@index([expiresAt])
}

/// A reusable household checklist — e.g. "Sac pour le trek", "Affaires chez
/// mamie". The list is a durable template: members tick items off when they
/// use it, then "Réinitialiser" un-checks everything for the next time.
/// Optionally linked to a recurring task template (see taskTemplateId).
model Checklist {
  id                String           @id @default(cuid())
  householdId       String
  createdByMemberId String?
  taskTemplateId    String?
  name              String
  icon              String?
  color             String           @default("#D8643D")
  isArchived        Boolean          @default(false)
  sortOrder         Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  household         Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdByMember   HouseholdMember? @relation("ChecklistCreator", fields: [createdByMemberId], references: [id], onDelete: SetNull)
  taskTemplate      TaskTemplate?    @relation(fields: [taskTemplateId], references: [id], onDelete: SetNull)
  items             ChecklistItem[]

  @@index([householdId, isArchived, sortOrder])
  @@index([taskTemplateId])
}

model ChecklistItem {
  id                String           @id @default(cuid())
  checklistId       String
  checkedByMemberId String?
  label             String
  isChecked         Boolean          @default(false)
  sortOrder         Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  checklist         Checklist        @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  checkedByMember   HouseholdMember? @relation("ChecklistItemChecker", fields: [checkedByMemberId], references: [id], onDelete: SetNull)

  @@index([checklistId, sortOrder])
}

/// A volatile, single-shot foyer reminder ("acheter du café", "appeler le
/// plombier"). Behaves like a shared FIFO inbox: created → done → moved to the
/// "Fait" list → purged after the household's noteRetentionDays window.
model HouseholdNote {
  id                  String           @id @default(cuid())
  householdId         String
  createdByMemberId   String?
  completedByMemberId String?
  title               String?
  body                String
  color               String           @default("#D8643D")
  isPinned            Boolean          @default(false)
  completedAt         DateTime?
  sortOrder           Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  household           Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdByMember     HouseholdMember? @relation("HouseholdNoteCreator", fields: [createdByMemberId], references: [id], onDelete: SetNull)
  completedByMember   HouseholdMember? @relation("HouseholdNoteCompleter", fields: [completedByMemberId], references: [id], onDelete: SetNull)

  @@index([householdId, completedAt, isPinned, sortOrder])
}

// ─────────────────────────────────────────────────────────────────────────────
// Budget — monthly household cash-flow tracker.
// « Reste sur le compte » = Revenus − Charges fixes − Dépenses du mois.
// Pockets are per-field spend budgets with a configurable monthly OR weekly
// quota. A charge may optionally point at a savings box (recurring épargne
// counted as a budget deduction — a light link, not the core).
// ─────────────────────────────────────────────────────────────────────────────

model BudgetIncome {
  id          String   @id @default(cuid())
  householdId String
  label       String
  amount      Decimal  @db.Decimal(12, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
}

model BudgetCharge {
  id           String   @id @default(cuid())
  householdId  String
  label        String
  amount       Decimal  @db.Decimal(12, 2)
  dayOfMonth   Int?
  savingsBoxId String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  household  Household   @relation(fields: [householdId], references: [id], onDelete: Cascade)
  savingsBox SavingsBox? @relation(fields: [savingsBoxId], references: [id], onDelete: SetNull)

  @@index([householdId])
  @@index([savingsBoxId])
}

model BudgetPocket {
  id          String   @id @default(cuid())
  householdId String
  name        String
  /// Optional emoji icon for personalisation (rendered as a string).
  icon        String?
  color       String   @default("#2F6D88")
  /// "monthly" | "weekly" — the period the quota resets on.
  period      String   @default("monthly")
  quota       Decimal  @db.Decimal(12, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  expenses  BudgetExpense[]

  @@index([householdId, sortOrder])
}

model BudgetExpense {
  id                String   @id @default(cuid())
  householdId       String
  pocketId          String?
  label             String?
  amount            Decimal  @db.Decimal(12, 2)
  /// Amount expected back (medical, pro fees…). Null = not a refundable expense.
  refundExpected    Decimal? @db.Decimal(12, 2)
  /// Amount actually received back so far (supports partial). Null = nothing yet.
  refundedAmount    Decimal? @db.Decimal(12, 2)
  spentAt           DateTime @default(now())
  createdByMemberId String?
  createdAt         DateTime @default(now())

  household       Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  pocket          BudgetPocket?    @relation(fields: [pocketId], references: [id], onDelete: SetNull)
  createdByMember HouseholdMember? @relation("BudgetExpenseCreator", fields: [createdByMemberId], references: [id], onDelete: SetNull)

  @@index([householdId, spentAt])
  @@index([pocketId])
}
