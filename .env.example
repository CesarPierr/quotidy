DATABASE_URL="postgresql://quotidy:quotidy@localhost:5432/quotidy?schema=public"
APP_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Quotidy"
NEXT_PUBLIC_CONTACT_EMAIL="contact@example.com"
NEXT_PUBLIC_SUPPORT_URL=""
AUTH_SECRET="change-me-in-production"
ADMIN_EMAILS=""
BILLING_ENABLED="0"
DEFAULT_TIMEZONE="Europe/Paris"
OCCURRENCE_PAST_DAYS="30"
OCCURRENCE_FUTURE_DAYS="60"

# REQUIRED in production. Use a strong random string (>=32 chars).
# Example: openssl rand -hex 32
CSRF_SECRET=""

# Cron-protected push dispatch endpoint (Bearer token).
CRON_SECRET=""

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:admin@quotidy.app"

# SMTP (optional — if not set, reset links are logged to console in dev)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@quotidy.local"

# Error tracking (optional, recommended for production).
# Get a DSN from https://sentry.io/ — leave empty to disable Sentry reporting.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# GitHub bug-report integration (optional). When set, the in-app "Signaler un problème"
# form opens a GitHub issue under this repo using the token. Token needs `issues:write`.
GITHUB_REPORT_REPO=""
GITHUB_REPORT_TOKEN=""

# Tuning toggles (set to "1" to disable for local debugging — never in production)
# RATE_LIMIT_DISABLED=""
# CSRF_DISABLED=""
# LOG_REQUESTS=""
